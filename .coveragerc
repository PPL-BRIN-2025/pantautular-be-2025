[run]
branch = True
relative_files = True
source =
    pt_backend.statistics
omit =
    */migrations/*
    */tests/*
    */tests.py
    */test_*.py
    */__pycache__/*
    expert_user_feature/conftest.py
    pt_backend/filter/date_range_filter.py
    pt_backend/views.py

[report]
show_missing = True
skip_covered = False
fail_under = 0
exclude_lines =
    pragma: no cover
    ^\s*if __name__ == ['"]__main__['"]:\s*$
    ^\s*@abstractmethod
    ^\s*raise NotImplementedError
