[run]
branch = True
relative_files = True
source =
    admin_feature
    curator_feature
    expert_user_feature
omit =
    */migrations/*
    */tests/*
    */tests.py
    */test_*.py
    */__pycache__/*
    expert_user_feature/conftest.py

[report]
show_missing = True
skip_covered = False
fail_under = 0
exclude_lines =
    pragma: no cover
    ^\s*if __name__ == ['"]__main__['"]:\s*$
    ^\s*@abstractmethod
    ^\s*raise NotImplementedError

# Remove [paths]; relative_files=True already yields repo-relative paths that Sonar maps correctly.
